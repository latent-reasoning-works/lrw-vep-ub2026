#!/usr/bin/env python3
"""Preflight: verify ClinVar data is present and BRCA1 is well-represented.

Run before any encode_*.yaml that touches `data=clinvar`. Fails fast with
actionable hints rather than letting Hydra spelunk through missing files.

Usage:
    python3 experiments/scripts/check_clinvar
    python3 experiments/scripts/check_clinvar --gene BRCA1 --min 100

Exit codes:
    0  all good
    1  data missing                   → see the printed pointer to the pipeline doc
    2  data present but gene under-represented for the demo
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

EXPECTED_FILES = ["variants.tsv", "dna.fasta", "rna.fasta", "protein.fasta"]
PIPELINE_DOC = "experiments/tools/manylatents-omics/docs/clinvar_pipeline.md"


def find_clinvar_dir() -> Path | None:
    """Resolve the ClinVar data dir the same way the Hydra config would."""
    candidates = []
    if env := os.environ.get("MANYLATENTS_DATA_DIR"):
        candidates.append(Path(env) / "clinvar")
    repo_root = Path(__file__).resolve().parent.parent.parent
    candidates.extend([
        repo_root / "data" / "clinvar",
        repo_root / "experiments" / "tools" / "manylatents-omics" / "data" / "clinvar",
        Path.home() / ".manylatents" / "data" / "clinvar",
    ])
    for c in candidates:
        if c.exists() and c.is_dir():
            return c
    return None


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__.split("\n")[0])
    parser.add_argument("--gene", default="BRCA1",
                        help="Gene symbol to verify representation for")
    parser.add_argument("--min", type=int, default=200,
                        help="Minimum variant count for the gene")
    args = parser.parse_args()

    data_dir = find_clinvar_dir()
    if data_dir is None:
        print("[FAIL] ClinVar data dir not found. Looked in:")
        print("  $MANYLATENTS_DATA_DIR/clinvar (env)")
        print("  <repo>/data/clinvar")
        print("  <repo>/experiments/tools/manylatents-omics/data/clinvar")
        print("  ~/.manylatents/data/clinvar")
        print()
        print(f"To prepare the data, follow {PIPELINE_DOC}")
        print("(downloads ClinVar VCF from NCBI + RefSeq, builds variants.tsv + per-modality FASTAs).")
        return 1
    print(f"[OK]  data dir: {data_dir}")

    missing = [f for f in EXPECTED_FILES if not (data_dir / f).exists()]
    if missing:
        print(f"[FAIL] missing files in {data_dir}: {missing}")
        print(f"       see {PIPELINE_DOC} → Stage 1 for the prep pipeline.")
        return 1
    print(f"[OK]  all {len(EXPECTED_FILES)} expected files present")

    variants = data_dir / "variants.tsv"
    try:
        gene_count = sum(
            1 for line in variants.read_text().splitlines()[1:]  # skip header
            if args.gene.upper() in line.upper().split("\t")
        )
    except Exception as e:
        print(f"[WARN] could not count {args.gene} variants: {e}")
        return 0
    print(f"[OK]  {args.gene} variants in TSV: {gene_count}")
    if gene_count < args.min:
        print(f"[WARN] only {gene_count} {args.gene} variants — below requested min of {args.min}.")
        print(f"       The demo uses max_variants=200; results will be smaller than asked for.")
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main())
