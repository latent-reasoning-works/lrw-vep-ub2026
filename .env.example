# Copy to .env and fill in. .env is gitignored.

# wandb — drives logging for every encode_*.yaml run with `logger: wandb`.
# Defaults baked into experiment configs via ${oc.env:WANDB_*,<default>}.
WANDB_ENTITY=cesar-valdez-mcgill-university
WANDB_PROJECT=upper-bound-2026
# 90s default times out on flaky conference Wi-Fi; bump for workshop runs.
WANDB_INIT_TIMEOUT=180
# WANDB_API_KEY is read from ~/.netrc after `wandb login`. Don't put it here.

# Hugging Face — only needed if a model gates download.
# HUGGING_FACE_HUB_TOKEN=

# Cluster (Phase 2 demo) — set when sbatch'ing to mila/tamia/drac.
# CLUSTER=mila

# Hosted-encoder backends (S4c "no-GPU path"). Pick the one matching the
# provider; see ARCHITECTURE.md §5 "Hosted-encoder backends" for the
# retry policy, vocab-ordering invariant, and parity-gating protocol.
# HF_API_KEY=                       # HuggingFace Inference Endpoints
# VLLM_API_KEY=                     # self-hosted vLLM deployment
# AWS_HEALTHOMICS_ROLE_ARN=         # AWS HealthOmics inference

# Backend selector read in the notebook's `s2-load-encoder` cell.
# WORKSHOP_ENCODER_BACKEND=local    # or `hosted`
